{"focus":{"id":"74df37a8-5572-588b-a649-6045601c2aab","caseIdentifierUUID":"6ba0b50b-d7cc-11e8-824f-0242ac160002","code":"8.G.B.8","description":"Apply the Pythagorean Theorem to find the distance between two points in a coordinate system.","statementType":"Standard","gradeLevels":["8"],"grade":"8","domain":"G","cluster":"8.G.B","level":"standard"},"ancestors":[{"id":"d865f537-3bc8-5143-81b9-3ade20de09d2","caseIdentifierUUID":"6b9fd7e9-d7cc-11e8-824f-0242ac160002","code":"2.MD.B.6","description":"Represent whole numbers as lengths from 0 on a number line diagram with equally spaced points corresponding to the numbers 0, 1, 2, …, and represent whole-number sums and differences within 100 on a number line diagram.","statementType":"Standard","gradeLevels":["2"],"grade":"2","domain":"MD","cluster":"2.MD.B","level":"standard"},{"id":"40edda9b-7aed-5802-8bff-d566f71df50d","caseIdentifierUUID":"6b9d400d-d7cc-11e8-824f-0242ac160002","code":"3.NF.A.2","description":"Understand a fraction as a number on the number line; represent fractions on a number line diagram.","statementType":"Standard","gradeLevels":["3"],"grade":"3","domain":"NF","cluster":"3.NF.A","level":"standard"},{"id":"ba2855ee-89aa-5bf2-9741-b2ef8a53d122","caseIdentifierUUID":"6b9d5464-d7cc-11e8-824f-0242ac160002","code":"5.G.A.2","description":"Represent real world and mathematical problems by graphing points in the first quadrant of the coordinate plane, and interpret coordinate values of points in the context of the situation.","statementType":"Standard","gradeLevels":["5"],"grade":"5","domain":"G","cluster":"5.G.A","level":"standard"},{"id":"d34ac232-6f89-53d4-8281-35ae2a7126ff","caseIdentifierUUID":"6b9e3d90-d7cc-11e8-824f-0242ac160002","code":"6.G.A.3","description":"Draw polygons in the coordinate plane given coordinates for the vertices; use coordinates to find the length of a side joining points with the same first coordinate or the same second coordinate. Apply these techniques in the context of solving real-world and mathematical problems.","statementType":"Standard","gradeLevels":["6"],"grade":"6","domain":"G","cluster":"6.G.A","level":"standard"},{"id":"baa2ebfe-b4ae-5424-b435-0978cbda8219","caseIdentifierUUID":"6ba063cb-d7cc-11e8-824f-0242ac160002","code":"8.G.B.7","description":"Apply the Pythagorean Theorem to determine unknown side lengths in right triangles in real-world and mathematical problems in two and three dimensions.","statementType":"Standard","gradeLevels":["8"],"grade":"8","domain":"G","cluster":"8.G.B","level":"standard"}],"descendants":[{"id":"b517efad-0cfa-5eb1-994f-70cb48476ba9","caseIdentifierUUID":"6b9c73d2-d7cc-11e8-824f-0242ac160002","code":"HSG-GPE.A.1","description":"Derive the equation of a circle of given center and radius using the Pythagorean Theorem; complete the square to find the center and radius of a circle given by an equation.","statementType":"Standard","gradeLevels":["9","10","11","12"],"grade":"HS","domain":"G-GPE","cluster":"HSG-GPE.A","level":"standard"},{"id":"4c04767d-6e2c-570c-946f-5664dab60615","caseIdentifierUUID":"6b9daa46-d7cc-11e8-824f-0242ac160002","code":"HSG-GPE.A.2","description":"Derive the equation of a parabola given a focus and directrix.","statementType":"Standard","gradeLevels":["9","10","11","12"],"grade":"HS","domain":"G-GPE","cluster":"HSG-GPE.A","level":"standard"},{"id":"cb3e6f20-d26c-5f6d-bae5-33d85ede580e","caseIdentifierUUID":"6b9e7402-d7cc-11e8-824f-0242ac160002","code":"HSG-GPE.A.3","description":"(+) Derive the equations of ellipses and hyperbolas given the foci, using the fact that the sum or difference of distances from the foci is constant.","statementType":"Standard","gradeLevels":["9","10","11","12"],"grade":"HS","domain":"G-GPE","cluster":"HSG-GPE.A","level":"standard"},{"id":"8e1de64e-487f-5145-a1ea-cf51f433d2b7","caseIdentifierUUID":"6b9f16e0-d7cc-11e8-824f-0242ac160002","code":"HSG-GPE.B.4","description":"Use coordinates to prove simple geometric theorems algebraically. *For exam