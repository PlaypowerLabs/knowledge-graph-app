{"focus":{"id":"baa2ebfe-b4ae-5424-b435-0978cbda8219","caseIdentifierUUID":"6ba063cb-d7cc-11e8-824f-0242ac160002","code":"8.G.B.7","description":"Apply the Pythagorean Theorem to determine unknown side lengths in right triangles in real-world and mathematical problems in two and three dimensions.","statementType":"Standard","gradeLevels":["8"],"grade":"8","domain":"G","cluster":"8.G.B","level":"standard"},"ancestors":[],"descendants":[{"id":"74df37a8-5572-588b-a649-6045601c2aab","caseIdentifierUUID":"6ba0b50b-d7cc-11e8-824f-0242ac160002","code":"8.G.B.8","description":"Apply the Pythagorean Theorem to find the distance between two points in a coordinate system.","statementType":"Standard","gradeLevels":["8"],"grade":"8","domain":"G","cluster":"8.G.B","level":"standard"},{"id":"4b576e40-8317-5342-99a9-f84b32754936","caseIdentifierUUID":"6b9e6a3a-d7cc-11e8-824f-0242ac160002","code":"HSF-TF.A.3","description":"(+) Use special triangles to determine geometrically the values of sine, cosine, tangent for $\\frac{\\pi}{3}$, $\\frac{\\pi}{4}$ and $\\frac{\\pi}{6}$, and use the unit circle to express the values of sine, cosine, and tangent for $\\pi-x$, $\\pi+x$, and $2\\pi-x$ in terms of their values for x, where x is any real number.","statementType":"Standard","gradeLevels":["9","10","11","12"],"grade":"HS","domain":"F-TF","cluster":"HSF-TF.A","level":"standard"},{"id":"c19d1d86-6056-5558-82a1-e8bc0f04654b","caseIdentifierUUID":"6ba0bf6b-d7cc-11e8-824f-0242ac160002","code":"HSF-TF.C.8","description":"Prove the Pythagorean identity $\\sin^{2}(\\theta) + \\cos^{2}(\\theta) = 1$ and use it to find $\\sin(\\theta)$, $\\cos(\\theta)$, or $\\tan(\\theta)$ given $\\sin(\\theta)$, $\\cos(\\theta)$, or $\\tan(\\theta)$ and the quadrant of the angle.","statementType":"Standard","gradeLevels":["9","10","11","12"],"grade":"HS","domain":"F-TF","cluster":"HSF-TF.C","level":"standard"},{"id":"7d4b0f0b-04e2-50aa-a0c1-0a690ded7b09","caseIdentifierUUID":"6ba0c5dc-d7cc-11e8-824f-0242ac16000